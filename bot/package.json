{
  "name": "cfb-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord bot for the CFB Team 360 MCP server -- deterministic slash commands (Phase A) plus a conversational Claude path (later phases).",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "register": "tsx scripts/register-commands.ts",
    "eval": "tsx evals/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "discord.js": "^14.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
