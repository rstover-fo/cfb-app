# CFB Discord bot -- environment configuration
# Copy to .env and fill in real values. Never commit .env.

# --- Required (Phase A) ---

# Discord bot token, from the Discord Developer Portal (Bot tab).
# DISCORD_TOKEN=

# Discord application (client) ID, from the Developer Portal (General Information tab).
# DISCORD_APP_ID=

# Guild (server) ID to register slash commands against. Guild-scoped registration
# propagates instantly, unlike global commands (which can take up to an hour).
# DISCORD_GUILD_ID=

# Base URL of the cfb-app hosted MCP server (streamable HTTP transport).
# MCP_URL=https://v0-production-data-application.vercel.app/api/mcp

# Bearer token cfb-app's MCP server expects (must match its MCP_AUTH_TOKEN env var).
# MCP_AUTH_TOKEN=

# --- Optional (Phase A) ---

# Overrides the season used when a command doesn't specify one. Defaults to an
# August-pivot rule (current year from August on, else the prior year) when unset.
# CFB_SEASON=

# --- Phase B (conversational /ask + @-mention path) ---

# Anthropic API key for the Claude conversational path. Optional: without it
# the deterministic slash commands still work, and /ask + @-mentions reply
# with a friendly "unavailable" message.
# ANTHROPIC_API_KEY=

# Model overrides for the conversational path (all optional).
# Default conversational model (simple-tier questions).
# MODEL_DEFAULT=claude-sonnet-5
# Advisor model for gnarly analytical questions and [ESCALATE] re-runs.
# MODEL_ADVISOR=claude-opus-4-8
# Cheap classifier model for simple-vs-gnarly routing.
# MODEL_ROUTER=claude-haiku-4-5

# --- Phase C (memory/profiles/cost guards) ---

# Where profiles.ts persists per-user favorite teams (/myteam). Relative
# paths resolve against process.cwd() (the bot/ workspace root in normal use).
# PROFILES_PATH=data/profiles.json

# Global daily spend ceiling in USD for the LLM path (limits.ts).
# DAILY_BUDGET_USD=10

# Max LLM-backed questions a single user can ask per day.
# USER_DAILY_LIMIT=10

# Minimum seconds between LLM-backed questions from the same user.
# COOLDOWN_SECONDS=20
